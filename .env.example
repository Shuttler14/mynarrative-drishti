# ─── Railway / Production ───────────────────────────
# Railway auto-sets PORT — do NOT override it.
# Railway plugin references: use ${{Postgres.DATABASE_URL}} etc. in the Railway UI.

ENV=production          # "production" or "local"
DEBUG=false

# ─── Database (Railway Postgres plugin) ─────────────
# Railway UI: set DATABASE_URL = ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql+asyncpg://drishti:drishti_secret@localhost:5432/drishti

# ─── Redis (Railway Redis plugin) ───────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant (Railway Docker service) ────────────────
# Internal URL: http://qdrant.railway.internal:6333
QDRANT_URL=http://localhost:6333

# ─── JWT ────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_to_a_64_char_random_string

# ─── Shopify ────────────────────────────────────────
SHOPIFY_STORE_URL=https://mynarrative.in
SHOPIFY_DOMAIN=jjdk0v-0c.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ─── CORS (JSON array or comma-separated) ──────────
CORS_ORIGINS=["https://mynarrative.in","https://www.mynarrative.in"]

# ─── GPU Workers ────────────────────────────────────
VTOE_GPU_URL=https://vton.mynarrative.in

# ─── AWS (DTF Pipeline) ────────────────────────────
S3_BUCKET=mynarrative-dtf-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1

# ─── Observability (optional — add later) ───────────
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# PROMETHEUS_ENABLED=true

# ─── SMTP (notifications) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Legacy (ignore on Railway) ────────────────────
ORACLE_HOST=
CLOUDFLARE_TUNNEL_URL=
SCRAPING_RATE_LIMIT=2
SCRAPING_PROXY_URL=
